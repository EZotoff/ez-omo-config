{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-openagent.schema.json",
  "agents": {
    "sisyphus": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "high",
      "fallback_models": [
        "kimi-code/k2p5"
      ],
      "skills": [
        "wisdom"
      ]
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "oracle": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview"
      ],
      "skills": [
        "wisdom"
      ]
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7"
    },
    "explore": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "github-copilot/grok-code-fast-1"
      ]
    },
    "multimodal-looker": {
      "model": "google/gemini-3.1-pro-preview"
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.1"
      ],
      "skills": [
        "wisdom"
      ]
    },
    "metis": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.4"
      ],
      "skills": [
        "wisdom"
      ]
    },
    "momus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "github-copilot/claude-opus-4.6"
      ],
      "skills": [
        "wisdom"
      ]
    },
    "atlas": {
      "model": "kimi-code/k2p5",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/gpt-5.4"
      ],
      "skills": [
        "wisdom"
      ],
      "prompt_append": "## Wisdom Injection Protocol\n\nBefore delegating EVERY task via task(), you MUST:\n1. Call wisdom_search to retrieve relevant system-level wisdom:\n   `~/.sisyphus/scripts/wisdom-search.sh \"TASK_KEYWORDS\" --scope system --limit 10 --json`\n2. Also check project-scoped wisdom if a project_id is known\n3. Include results in the '## 6. CONTEXT' section under '### Inherited Wisdom from System'\n4. After each task completes, check if new learnings should be written via wisdom-write.sh\n5. After each task() call completes, run `~/.sisyphus/scripts/wisdom-sync.sh` to sync new notepad learnings"
    },
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "skills": [
        "wisdom"
      ]
    },
    "frontend-ui-ux-engineer": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "fallback_models": [
        "zai-coding-plan/glm-5.1"
      ],
      "description": "Senior UI/UX engineer for COMPLEX frontend work: design system creation, multi-component refactors, accessibility audits, animation choreography, responsive layout architecture, component library design. Uses Gemini 3 Pro for deeper reasoning. Use ui-quick for simple tasks instead."
    },
    "document-writer": {
      "model": "kimi-code/k2p5",
      "fallback_models": [
        "zai-coding-plan/glm-5.1"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.1"
      ],
      "prompt_append": "Use shadcn/ui components and Tailwind CSS."
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.1"
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "github-copilot/claude-opus-4.6"
      ]
    },
    "quick": {
      "model": "deepseek/deepseek-chat"
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.4"
      ]
    },
    "writing": {
      "model": "kimi-code/k2p5",
      "fallback_models": [
        "opencode-go/kimi-k2.5"
      ]
    },
    "deep": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "high",
      "fallback_models": [
        "github-copilot/claude-opus-4.6"
      ]
    },
    "mephistopheles": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "github-copilot/claude-opus-4.6"
      ],
      "prompt_append": "You are Mephistopheles, an adversarial reasoning agent. Your approach: FIRST genuinely acknowledge the strongest aspects of any position presented to you. THEN systematically dismantle weaknesses with rigorous logic. You are generous but relentless — you give credit where due, then show exactly where and why the argument fails. Never be dismissive or condescending. Your goal is to strengthen ideas through adversarial pressure, not to 'win'. When you find an argument genuinely strong, say so explicitly."
    }
  },
  "google_auth": false,
  "auto_update": false,
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      404,
      429,
      500,
      502,
      503,
      504
    ]
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  },
  "experimental": {
    "preemptive_compaction": false,
    "aggressive_truncation": true,
    "truncate_all_tool_outputs": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search"
      ],
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  }
}
