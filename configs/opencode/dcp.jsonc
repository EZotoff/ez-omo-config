{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",

  // ──────────────────────────────────────────────────────────────
  // PREVIOUS CUSTOM SETTINGS (reset to v3 defaults 2026-04-13)
  // Restore selectively if needed:
  //
  //   pruneNotification: "minimal"            (now: "detailed")
  //   commands.protectedTools: ["task","todowrite","todoread","skill"]  (now: [])
  //   turnProtection: { enabled: true, turns: 3 }   (now: disabled)
  //   protectedFilePatterns: ["AGENTS.md","*.config.*","*.jsonc","oh-my-openagent.json"]  (now: [])
  //   compress.maxContextLimit: "55%"          (now: 100000)
  //   compress.minContextLimit: "30%"          (now: 50000)
  //   compress.nudgeFrequency: 10             (now: 5)
  //   compress.nudgeForce: "strong"           (now: "soft")
  //   compress.protectUserMessages: true       (now: false)
  //   compress.protectedTools: ["task","todowrite","todoread","skill","lsp_diagnostics"]  (now: [])
  //   strategies.deduplication.protectedTools: ["task","skill"]  (now: [])
  //   strategies.purgeErrors.turns: 5          (now: 4)
  //   strategies.purgeErrors.protectedTools: ["task"]  (now: [])
  //   experimental.allowSubAgents: true        (now: false)
  // ──────────────────────────────────────────────────────────────

  "enabled": true,
  "debug": false,
  "pruneNotification": "detailed",
  "pruneNotificationType": "chat",
  "commands": {
    "enabled": true,
    "protectedTools": []
  },
  "manualMode": {
    "enabled": false,
    "automaticStrategies": true
  },
  "turnProtection": {
    "enabled": false,
    "turns": 4
  },
  "protectedFilePatterns": [],
  "compress": {
    "mode": "range",
    "permission": "allow",
    "showCompression": false,
    "summaryBuffer": true,
    "maxContextLimit": 100000,
    "minContextLimit": 50000,
    "nudgeFrequency": 5,
    "iterationNudgeThreshold": 15,
    "nudgeForce": "soft",
    "modelMaxLimits": {
      "zai-coding-plan/glm-5.1": 75000
    },
    "modelMinLimits": {
      "zai-coding-plan/glm-5.1": 50000
    },
    "protectedTools": [],
    "protectUserMessages": false
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": []
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 4,
      "protectedTools": []
    }
  },
  "experimental": {
    "allowSubAgents": false,
    "customPrompts": false
  }
}
